{
  "name": "github-action-working-directory",
  "version": "1.0.0",
  "description": "GitHub Action that clones a repo into a working directory at step start and commits any changes back at step end (via main/post hooks).",
  "private": true,
  "type": "module",
  "author": "Cameron Tacklind <cameron@tacklind.com>",
  "license": "MIT",
  "keywords": [
    "github-actions",
    "git",
    "clone",
    "commit",
    "working-directory"
  ],
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "build:clone": "bun build src/clone.ts --target=node --format=cjs --outfile=dist/clone/index.js",
    "build:commit": "bun build src/commit.ts --target=node --format=cjs --outfile=dist/commit/index.js",
    "build": "bun run build:clone && bun run build:commit",
    "lint": "tsc --noEmit",
    "test": "bun test src",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinderblock/github-action-working-directory.git"
  },
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.19.19",
    "prettier": "^3.5.0",
    "typescript": "^6.0.3"
  }
}
